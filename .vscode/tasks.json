{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Levela Dev Server",
      "type": "process",
      "command": "${workspaceFolder}/scripts/start-dev-server.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "runOptions": {
        "runOn": "folderOpen",
        "instanceLimit": 1
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false,
        "focus": false
      },
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(ready in \\d+ ms|Local:\\s+http)"
        }
      }
    }
  ]
}
