{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Levela Dev Server",
      "type": "process",
      "command": "/bin/bash",
      "args": ["-c", "npm run dev:auto"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "runOptions": {
        "runOn": "folderOpen",
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
